{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": "./site",
    "paths": {
      "@components/*": [
        "./src/assets/components/*"
      ],
      "@utils/*": [
        "./src/assets/utils/*"
      ],
      "@img/*": [
        "./src/assets/img/*"
      ],
      "@css/*": [
        "./src/assets/css/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "site/dist",
    ".next",
    "site/src/landing-page/my-work/duck-story/beginning.tsx",
    "site/src/landing-page/my-work/duck-story/story.tsx",
    "site/src/landing-page/my-work/duck-story/pizza.tsx",
    "site/src/landing-page/my-work/duck-story/duck-front-page.tsx"
  ]
}
